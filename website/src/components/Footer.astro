---
const year = new Date().getFullYear();

const resourceLinks = [
  { href: '/docs', label: '文档' },
  { href: '/docs#installation', label: '快速安装' },
  { href: '/docs#configuration', label: '配置指南' },
];

const editorLinks = [
  { href: '/docs#vscode', label: 'VSCode' },
  { href: '/docs#neovim', label: 'Neovim' },
  { href: '/docs#zed', label: 'Zed' },
  { href: '/docs#emacs', label: 'Emacs' },
];
---

<footer class="border-t" style="border-color: var(--border); background: var(--bg);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-4 group w-fit">
          <div class="w-6 h-6 rounded-sm flex items-center justify-center" style="background: var(--btn-primary-bg);">
            <span class="font-mono font-bold text-xs" style="color: var(--btn-primary-fg);">L</span>
          </div>
          <span class="font-mono font-semibold text-sm tracking-tight" style="color: var(--text-heading);">LSP-PROXY.</span>
        </a>
        <p class="text-xs font-mono leading-relaxed max-w-xs" style="color: var(--text-dim);">
          透明代理插入编辑器与 LSP 之间，<br />将英文文档实时翻译为中文。
        </p>
        <div class="flex items-center gap-4 mt-4">
          <a href="https://github.com/zerx-lab/LspProxy" target="_blank" rel="noopener noreferrer"
            class="transition-colors" style="color: var(--text-dim);">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Resources -->
      <div>
        <p class="section-label mb-4">资源</p>
        <ul class="space-y-2">
          {resourceLinks.map(link => (
            <li>
              <a href={link.href} class="font-mono text-xs transition-colors footer-link" style="color: var(--text-dim);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Editors -->
      <div>
        <p class="section-label mb-4">编辑器集成</p>
        <ul class="space-y-2">
          {editorLinks.map(link => (
            <li>
              <a href={link.href} class="font-mono text-xs transition-colors footer-link" style="color: var(--text-dim);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 border-t" style="border-color: var(--border-subtle);">
      <p class="font-mono text-xs" style="color: var(--text-dim);">
        &copy; {year} LspProxy. MIT License.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/zerx-lab/LspProxy" class="font-mono text-xs transition-colors footer-link" style="color: var(--text-dim);">GitHub</a>
        <span style="color: var(--border);">/</span>
        <a href="/docs" class="font-mono text-xs transition-colors footer-link" style="color: var(--text-dim);">Docs</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--text-heading) !important;
  }
  footer a:hover svg {
    color: var(--text-heading);
  }
</style>
